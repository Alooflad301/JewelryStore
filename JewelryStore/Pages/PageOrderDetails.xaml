<Page x:Class="JewelryStore.Pages.PageOrderDetails"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JewelryStore.Pages"
      mc:Ignorable="d" 
       d:DesignHeight="500" d:DesignWidth="900">

    <Grid Margin="20" Background="#FFAFAFAF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок заказа -->
            <RowDefinition Height="*"/>
            <!-- Товары -->
            <RowDefinition Height="Auto"/>
            <!-- Итог -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock x:Name="tbOrderNumber" Text="#1" FontSize="28" FontWeight="Bold"/>
            <Button Content="Назад" Width="100" Height="35" Margin="20,0,0,0" FontSize="20" 
                    Click="BackButton_Click"/>
        </StackPanel>

        <!-- Товары заказа -->
        <ListView Grid.Row="1" x:Name="listOrderItems" Margin="0,0,0,20">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <!-- Название -->
                            <ColumnDefinition Width="*"/>
                            <!-- Тип -->
                            <ColumnDefinition Width="80"/>
                            <!-- Кол-во -->
                            <ColumnDefinition Width="120"/>
                            <!-- Цена -->
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Jewelry.NameJewelry}" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="{Binding JewelryTip.NameJewelryTip}" FontSize="14"/>
                        <TextBlock Grid.Column="2" Text="{Binding Quantity}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="{Binding TotalPrice}" FontSize="16" FontWeight="Bold"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <TextBlock Grid.Row="2" x:Name="tbOrderTotal" Text="Итого: 0 руб." 
                   FontSize="24" FontWeight="Bold" HorizontalAlignment="Right"/>
    </Grid>
</Page>
