<Page x:Class="JewelryStore.Pages.PageReg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JewelryStore.Pages"
      mc:Ignorable="d"
      d:DesignHeight="500" d:DesignWidth="800"
      Title="PageReg">

    <Grid Loaded="PageReg_Loaded">
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF64FB82"/>
                <GradientStop Color="#FF54A564" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label Content="Регистрация" VerticalAlignment="Top" HorizontalContentAlignment="Center" FontFamily="Nirmala UI" FontSize="36" Foreground="Black" FontWeight="Bold"/>
            <Label Content="Логин" Margin="5" VerticalAlignment="Top" HorizontalContentAlignment="Center" FontFamily="Nirmala UI" Foreground="Black" FontSize="18" FontWeight="Bold"/>
            <TextBox x:Name="LoginBox" VerticalContentAlignment="Center" HorizontalAlignment="Center"  TextWrapping="Wrap"  VerticalAlignment="Top" Width="254" FontFamily="Nirmala UI" FontSize="14"/>
            <Label Content="Пароль" Margin="5" VerticalAlignment="Top"  HorizontalContentAlignment="Center" FontFamily="Nirmala UI"  Foreground="Black" FontSize="18" FontWeight="Bold"/>
            <PasswordBox x:Name="Password1" VerticalContentAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Top" Width="254" FontFamily="Nirmala UI" FontSize="14"/>
            <Label Content="Потвердите пароль" Margin="5" VerticalAlignment="Top"  HorizontalContentAlignment="Center" FontFamily="Nirmala UI"  Foreground="Black" FontSize="18" FontWeight="Bold"/>
            <PasswordBox x:Name="Password2" VerticalContentAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Top" Width="254" FontFamily="Nirmala UI" FontSize="14" PasswordChanged="Password2_PasswordChanged"/>
            <Label Content="Телефон" Margin="5" VerticalAlignment="Top"  HorizontalContentAlignment="Center" FontFamily="Nirmala UI" FontSize="18"  Foreground="Black" FontWeight="Bold"/>
            <TextBox x:Name="TelevonBox" VerticalContentAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"  VerticalAlignment="Top" Width="254" FontFamily="Nirmala UI" FontSize="14"/>
            <Label Content="Почта" Margin="5" VerticalAlignment="Top"  HorizontalContentAlignment="Center" FontFamily="Nirmala UI" FontSize="18"  Foreground="Black" FontWeight="Bold"/>
             <TextBox x:Name="EmailBox" VerticalContentAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Top" Width="254" FontFamily="Nirmala UI" FontSize="14"/>
            <Button x:Name="RegBut" Content="Зарегестрироватся" HorizontalAlignment="Center" Margin="0,20,0,0" VerticalAlignment="Top" FontFamily="Nirmala UI" FontSize="18" Width="254" Click="RegBut_Click" FontWeight="Bold" Background="White"/>
            <Button x:Name="HomeBut" Content="Назад" HorizontalAlignment="Center" Margin="5" VerticalAlignment="Top" FontFamily="Nirmala UI" FontSize="18" Width="254" Click="HomeBut_Click" FontWeight="Bold" Background="White"/>
           
            
            
            
           
        </StackPanel>
    </Grid>
</Page>
