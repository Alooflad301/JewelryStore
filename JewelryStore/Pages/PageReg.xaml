<Page x:Class="JewelryStore.Pages.PageReg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JewelryStore.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageReg">

    <Grid Background="White">
        <Label Content="Регистрация" HorizontalAlignment="Center" Margin="0,7,0,0" VerticalAlignment="Top" FontFamily="Segoe Print" FontSize="36"/>
        <Label Content="Логин" HorizontalAlignment="Center" Margin="0,59,0,0" VerticalAlignment="Top" FontFamily="Segoe Print" FontSize="20"/>
        <Label Content="Пароль" HorizontalAlignment="Center" Margin="0,119,0,0" VerticalAlignment="Top" FontFamily="Segoe Print" FontSize="20"/>
        <Label Content="Потвердите пароль" HorizontalAlignment="Center" Margin="0,177,0,0" VerticalAlignment="Top" FontFamily="Segoe Print" FontSize="20"/>
        <Label Content="Телефон" HorizontalAlignment="Center" Margin="0,232,0,0" VerticalAlignment="Top" FontFamily="Segoe Print" FontSize="20"/>
        <Label Content="Почта" HorizontalAlignment="Center" Margin="0,287,0,0" VerticalAlignment="Top" FontFamily="Segoe Print" FontSize="20"/>
        <Button x:Name="RegBut" Content="Зареган" HorizontalAlignment="Center" Margin="0,367,0,0" VerticalAlignment="Top" FontFamily="Segoe Print" FontSize="16" Width="120" Click="RegBut_Click"/>
        <Button x:Name="HomeBut" Content="Иди домой" HorizontalAlignment="Center" Margin="0,407,0,0" VerticalAlignment="Top" FontFamily="Segoe Print" FontSize="16" Width="118"/>
        <PasswordBox x:Name="Password1" HorizontalAlignment="Center" Margin="0,160,0,0" VerticalAlignment="Top" Width="120" FontFamily="Segoe Print" FontSize="14"/>
        <PasswordBox x:Name="Password2" HorizontalAlignment="Center" VerticalAlignment="Top" Width="120" FontFamily="Segoe Print" FontSize="14" PasswordChanged="Password2_PasswordChanged" Margin="0,217,0,0"/>
        <TextBox x:Name="LoginBox" HorizontalAlignment="Center" Margin="0,101,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="118" FontFamily="Segoe Print" FontSize="14"/>
        <TextBox x:Name="TelevonBox"  HorizontalAlignment="Center" Margin="0,270,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="120" FontFamily="Segoe Print" FontSize="14"/>
        <TextBox x:Name="EmailBox" HorizontalAlignment="Center" Margin="0,326,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120" FontFamily="Segoe Print" FontSize="14"/>
        <Label Content="Не реагет 2" HorizontalAlignment="Left" Margin="54,68,0,0" VerticalAlignment="Top">
            <UIElement.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </UIElement.RenderTransform>
        </Label>

    </Grid>
</Page>
