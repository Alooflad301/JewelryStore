<Page x:Class="JewelryStore.Pages.PageReg"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JewelryStore.Pages"
      mc:Ignorable="d"
      d:DesignHeight="500" d:DesignWidth="800"
      Title="PageReg">

    <Grid Background="White" Loaded="PageReg_Loaded">
        <Grid VerticalAlignment="Center">
            <Label Content="Регистрация" VerticalAlignment="Top" HorizontalContentAlignment="Center" FontFamily="Comic Sans MS" FontSize="36"/>
            <Label Content="Логин" Margin="0,58,0,0" VerticalAlignment="Top" HorizontalContentAlignment="Center" FontFamily="Comic Sans MS" FontSize="20"/>
            <Label Content="Пароль" Margin="0,115,0,0" VerticalAlignment="Top"  HorizontalContentAlignment="Center" FontFamily="Comic Sans MS" FontSize="20"/>
            <Label Content="Потвердите пароль" Margin="0,173,0,0" VerticalAlignment="Top"  HorizontalContentAlignment="Center" FontFamily="Comic Sans MS" FontSize="20"/>
            <Label Content="Телефон" Margin="0,229,0,0" VerticalAlignment="Top"  HorizontalContentAlignment="Center" FontFamily="Comic Sans MS" FontSize="20"/>
            <Label Content="Почта" Margin="0,284,0,0" VerticalAlignment="Top"  HorizontalContentAlignment="Center" FontFamily="Comic Sans MS" FontSize="20"/>
            <Button x:Name="RegBut" Content="Зарегестрироватся" HorizontalAlignment="Center" Margin="0,359,0,0" VerticalAlignment="Top" FontFamily="Comic Sans MS" FontSize="16" Width="254" Click="RegBut_Click"/>
            <Button x:Name="HomeBut" Content="Назад" HorizontalAlignment="Center" Margin="0,392,0,0" VerticalAlignment="Top" FontFamily="Comic Sans MS" FontSize="16" Width="254" Click="HomeBut_Click"/>
            <PasswordBox x:Name="Password1" HorizontalAlignment="Center" Margin="0,155,0,0" VerticalAlignment="Top" Width="254" FontFamily="Comic Sans MS" FontSize="14"/>
            <PasswordBox x:Name="Password2" HorizontalAlignment="Center" VerticalAlignment="Top" Width="254" FontFamily="Comic Sans MS" FontSize="14" PasswordChanged="Password2_PasswordChanged" Margin="0,210,0,0"/>
            <TextBox x:Name="LoginBox" HorizontalAlignment="Center" Margin="0,97,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="254" FontFamily="Comic Sans MS" FontSize="14"/>
            <TextBox x:Name="TelevonBox"  HorizontalAlignment="Center" Margin="0,267,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" Width="254" FontFamily="Comic Sans MS" FontSize="14"/>
            <TextBox x:Name="EmailBox" HorizontalAlignment="Center" Margin="0,322,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="254" FontFamily="Comic Sans MS" FontSize="14"/>
        </Grid>
    </Grid>
</Page>
