<Page x:Class="JewelryStore.Pages.PageAftoriz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JewelryStore.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="800"
      Title="PageAftoriz" Background="Black">

    <Grid Loaded="Aftor_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="217*"/>
            <RowDefinition Height="183*"/>
        </Grid.RowDefinitions>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF54A564"/>
                <GradientStop Color="#FF54A564" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid VerticalAlignment="Top" Margin="0,20,0,0" Grid.RowSpan="2">
            <Label Content="Авторизация" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" FontFamily="Nirmala UI" FontSize="48" Foreground="#FF5A0796" FontWeight="Bold" FontStyle="Italic"/>
            <Label Content="Логин" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,132,0,0" VerticalAlignment="Top" FontFamily="Nirmala UI" FontSize="24"  Foreground="#FF5A0796" FontWeight="Bold" FontStyle="Italic"/>
            <Label Content="Пароль" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,209,0,0" VerticalAlignment="Top" FontFamily="Nirmala UI" FontSize="24"  Foreground="#FF5A0796" FontWeight="Bold" FontStyle="Italic"/>
            <Button x:Name="DaBtn" Content="Потвердить" HorizontalAlignment="Stretch" Margin="0,292,0,0" VerticalAlignment="Top" Height="31" Width="344" FontFamily="Nirmala UI" FontSize="18" Foreground="#FF5A0796"  Click="DaBtn_Click" Background="White" FontWeight="Bold"/>
            <Button x:Name="Regtodt" Content="Регистрация" HorizontalAlignment="Stretch" Margin="0,328,0,0" VerticalAlignment="Top" Height="31" Width="344" FontFamily="Nirmala UI" FontSize="18" Foreground="#FF5A0796"  Click="Regtodt_Click" Background="White" FontWeight="Bold">
                <UIElement.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </UIElement.RenderTransform>
            </Button>
            <TextBox x:Name="TextLogin" HorizontalAlignment="Stretch" Margin="0,180,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="348" Height="25" FontFamily="Nirmala UI" />
            <PasswordBox x:Name="PassBox" Margin="226,255,226,0" VerticalAlignment="Top" Width="348" Height="25" FontFamily="Nirmala UI"/>
        </Grid>
    </Grid>
</Page>
