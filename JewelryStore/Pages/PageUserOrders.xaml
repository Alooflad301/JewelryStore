<Page x:Class="JewelryStore.Pages.PageUserOrders"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JewelryStore.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1250"
      Title="PageUserOrders" Loaded="Page_Loaded">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF64FB82"/>
                <GradientStop Color="#FF54A564" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="20,20,20,10">
            <TextBlock Text="Мои заказы" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0" FontFamily="Nirmala UI"/>
            <ComboBox x:Name="StatusFilter" Width="200" Height="35" Margin="10" 
                      SelectionChanged="StatusFilter_SelectionChanged"
                      DisplayMemberPath="NameStatusOrder"
                      SelectedValuePath="IdStatusOrder"
                      FontSize="14" FontFamily="Nirmala UI"/>
            <Button x:Name="BackCatalogButton" Content="Каталог" Width="140" Height="35" Margin="10" 
                    FontSize="16" Click="BackCatalogButton_Click" Background="White" FontWeight="Bold" FontFamily="Nirmala UI"/>
        </StackPanel>

        <ListView Grid.Row="1" x:Name="listOrders" Margin="20,10" SelectionChanged="listOrders_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#E0E0E0" BorderThickness="3" Margin="5" CornerRadius="10" Background="White" Width="1200">
                        <Grid Margin="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding IdOrder}" FontSize="20" FontWeight="Bold" 
                                           HorizontalAlignment="Center" Foreground="#FF421A56"/>
                                <TextBlock Text="{Binding OrderDate, StringFormat='dd.MM'}" FontSize="11" 
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1" Text="{Binding OrderDate, StringFormat='HH:mm'}" 
                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="2" Text="{Binding StatusName}" FontSize="14" FontWeight="Bold" 
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>

                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CustomerName}" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding CustomerPhone}" FontSize="12"/>
                                <TextBlock Text="{Binding CustomerEmail}" FontSize="11" Foreground="Blue"/>
                            </StackPanel>

                            <TextBlock Grid.Column="4" Text="{Binding DeliveryAddress}" FontSize="13" 
                                       VerticalAlignment="Center" TextWrapping="NoWrap"/>

                            <TextBlock Grid.Column="5" 
                                       Text="{Binding TotalPrice, StringFormat='Итого: {0:N0} руб.'}" 
                                       FontSize="16" FontWeight="Bold" 
                                       VerticalAlignment="Center" HorizontalAlignment="Center" 
                                       Foreground="#2E7D32" Margin="5,0,0,0"/>

                            <Button Grid.Column="6" Content="👁️" Width="40" Height="40" 
                                    VerticalAlignment="Center" Click="ViewOrder_Click" 
                                    Tag="{Binding IdOrder}" Background="Transparent" BorderThickness="0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2" Height="60" Margin="20,0">
            <TextBlock x:Name="tbStats" Text="Заказов: 0 | На сумму: 0 руб." 
                       FontSize="20" FontWeight="Bold" 
                       HorizontalAlignment="Right" VerticalAlignment="Center" Margin="30" Foreground="#FF0E0A0A"/>
        </Border>
    </Grid>
</Page>