<Page x:Class="JewelryStore.Pages.PageCheckout"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JewelryStore.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="PageCheckout">

    <Grid Margin="20" Background="#FFBD4141">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="📦 Оформление заказа" FontSize="32" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#FF421A56"/>

        <!-- Корзина (Run без ошибок!) -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListView Grid.Column="0" x:Name="listCartPreview" Height="250">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5" Background="LightGray">
                            <!-- Название -->
                            <TextBlock Text="{Binding Jewelry.NameJewelry}" Width="280" FontWeight="SemiBold" 
                                       VerticalAlignment="Center"/>

                            <!-- Количество (Run) -->
                            <TextBlock Width="70" VerticalAlignment="Center">
                                <Run Text="{Binding Quantity}"/>
                                <Run Text=" шт."/>
                            </TextBlock>

                            <!-- Цена за шт (Run) -->
                            <TextBlock Width="110" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Run Text="{Binding Jewelry.PriceJewelry}"/>
                                <Run Text=" руб."/>
                            </TextBlock>

                            <!-- Итог (Run) -->
                            <TextBlock Width="140" FontWeight="Bold" Foreground="#FF2E7D32" 
                                       HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Run Text="= "/>
                                <Run Text="{Binding TotalPrice}"/>
                                <Run Text=" руб."/>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Итог -->
            <TextBlock Grid.Column="1" x:Name="tbTotalPreview" 
                       Text="Итого: 0 руб." FontSize="24" FontWeight="Bold" 
                       VerticalAlignment="Bottom" Margin="10"/>
        </Grid>

        <!-- Данные доставки -->
        <GroupBox Grid.Row="2" Header="📍 Данные для доставки" Margin="0,0,0,20">
            <StackPanel Margin="15">
                <TextBlock Text="ФИО:*" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="CustomerNameText" Height="30"/>

                <TextBlock Text="Телефон:*" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="PhoneText" Height="30"/>

                <TextBlock Text="Адрес доставки:*" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="AddressText" Height="60" AcceptsReturn="True"/>

                <TextBlock Text="Комментарий к заказу:" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="CommentText" Height="60" AcceptsReturn="True"/>
            </StackPanel>
        </GroupBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button x:Name="ConfirmOrderButton" Content="Оформить заказ" 
                    Width="200" Height="50" FontSize="18" FontWeight="Bold"
                    Background="#FF2E7D32" Foreground="White" 
                    Click="ConfirmOrderButton_Click" Margin="15"/>
            <Button x:Name="BackButton" Content="Вернуться в корзину" 
                    Width="200" Height="50" FontSize="18"
                    Background="#FF757575" Foreground="White" 
                    Click="BackButton_Click" Margin="15"/>
        </StackPanel>
    </Grid>
</Page>