<Page x:Class="JewelryStore.Pages.PageJewelryCatalog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JewelryStore.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="1250"
      Title="PageJewelryCatalog" Loaded="Jc">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="0">
            <ComboBox x:Name="ComboFilter" Margin="5" Height="26" Width="197" SelectionChanged="ComboFilter_SelectionChanged"/>
            <ComboBox x:Name="ComdoSort"  Margin="5" VerticalAlignment="Center" Width="159" Height="26" SelectionChanged="ComdoSort_SelectionChanged"/>
            <ComboBox x:Name="ComdoMat"  Margin="5" VerticalAlignment="Center" Width="171" Height="26" SelectionChanged="ComdoMat_SelectionChanged"/>
            <ComboBox x:Name="ComdoStone"  Margin="5" VerticalAlignment="Center" Width="171" Height="26" SelectionChanged="ComdoStone_SelectionChanged"/>
            <ComboBox x:Name="ComdoSup"  Margin="5" VerticalAlignment="Center" Width="171" Height="26" SelectionChanged="ComdoSup_SelectionChanged"/>
            <TextBox x:Name="TextSearch" Margin="5" TextWrapping="Wrap" Width="186" Height="26" TextChanged="TextSearch_TextChanged"/>
            <Button x:Name="SbrosBut" Margin="5" Content="Сброс" Height="26" Width="91" Click="SbrosBut_Click"/>
        </StackPanel>
        <ListView Grid.Row="1" x:Name="listProduct" Margin="0,8,0,15" >
            <ListView.Background>
                <RadialGradientBrush>
                    <GradientStop Color="#FFCACACA" Offset="0"/>
                    <GradientStop Color="#FFA0A0A0" Offset="1"/>
                </RadialGradientBrush>
            </ListView.Background>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Border
                            Width="200"
                            Height="200"
                            Margin="3"
                            ClipToBounds="True"
                            Grid.Column="0">
                                <Image Source="{Binding CurrentPhoto}" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel  Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Left">
                                <TextBlock  Height="auto" Text="{Binding NameJewelry}"/>
                                <TextBlock TextWrapping="Wrap" Height="auto" Margin="0,0,0,20">
                            <Run Text="Категория укарашения: "/>
                             <Run Text="{Binding JewelryTip.NameJewelryTip}"/>

                                </TextBlock>
                                <TextBlock TextWrapping="Wrap"  Height="auto" Margin="0,0,0,20">
                                    <Run Text="Материал: "/>
                                    <Run Text="{Binding Material.NameMaterial}"/>

                                </TextBlock>
                                <TextBlock TextWrapping="Wrap"  Height="auto" Margin="0,0,0,10">
                                    <Run Text="Камень: "/>
                                    <Run Text="{Binding Stone.NameStone}"/>

                                </TextBlock>
                                <TextBlock TextWrapping="Wrap"  Height="auto" Margin="0,0,0,10">
    <Run Text="Бренд: "/>
    <Run Text="{Binding Supplier.NameSupplier}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock TextWrapping="Wrap"  Height="auto" Margin="0,0,0,10">
                                            <Run Text="Цена: "/>
                                            <Run Text="{Binding PriceJewelry}"/>
                                            <Run Text=" руб."/>
                                </TextBlock>

                            </StackPanel>
                        </Grid>
                    </Border>

                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>
        <TextBlock x:Name="tbCounter" HorizontalAlignment="Left" Margin="10,0,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Center" Grid.Row="2" Foreground="White" FontSize="18"/>


        <Grid.Background>
            <RadialGradientBrush>
                <GradientStop Color="#FFD41891" Offset="0"/>
                <GradientStop Color="#FF421A56" Offset="1"/>
                <GradientStop Color="#FFAF0000" Offset="2"/>
                <GradientStop Color="#FFC11C02" Offset="2"/>
                <GradientStop Color="#FFFF0404" Offset="4"/>
            </RadialGradientBrush>
        </Grid.Background>
    </Grid>
</Page>
