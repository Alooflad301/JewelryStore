<Page x:Class="JewelryStore.Pages.PageCart"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JewelryStore.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="900"
      Title="PageCart">
    <Grid Background="#FF4FAF03">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>

        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Корзина" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Margin="20" Foreground="#FF421A56"/>
        <ListView Grid.Row="1" x:Name="listCart" Margin="20,10">
            <ListView.Background>
                <RadialGradientBrush>
                    <GradientStop Color="#FFCACACA" Offset="0"/>
                    <GradientStop Color="#FFA0A0A0" Offset="1"/>
                </RadialGradientBrush>
            </ListView.Background>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderThickness="1" Margin="2" CornerRadius="8">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="160" Height="160" Grid.Column="0" Margin="0,0,10,0">
                                <Image Source="{Binding Jewelry.CurrentPhoto}" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Jewelry.NameJewelry}" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Jewelry.JewelryTip.NameJewelryTip}" Margin="0,5"/>
                                <TextBlock Text="{Binding Jewelry.Material.NameMaterial}" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Jewelry.Supplier.NameSupplier}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Количество:" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="-" Width="30" Height="30" Margin="5" 
                                        Click="DecreaseQuantity_Click" Tag="{Binding IdCartItem}"/>
                                    <TextBlock x:Name="QuantityText" Text="{Binding Quantity}" 
                                           FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
                                    <Button Content="+" Width="30" Height="30" Margin="5" 
                                        Click="IncreaseQuantity_Click" Tag="{Binding IdCartItem}"/>
                                </StackPanel>
                                <Button Content="🗑️ Удалить" Width="100" Height="28" Margin="5,10,5,0" 
                                    Click="RemoveItem_Click" Tag="{Binding IdCartItem}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Jewelry.PriceJewelry, StringFormat='Цена: {0} руб.'}" 
                                       FontSize="14" Margin="0,0,0,5"/>
                                <TextBlock x:Name="ItemTotalText" Text="{Binding TotalPrice, StringFormat='Итого: {0} руб.'}" 
                                       FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Border Grid.Row="2" Height="80" Margin="20,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20">
                <TextBlock Text="{Binding ElementName=listCart, Path=Items.Count, StringFormat='Товаров: {0}'}" FontSize="24" FontWeight="Bold" Margin="0,0,30,0" Foreground="White"/>
                <TextBlock x:Name="tbTotal" Text="Итого: 0 руб." FontSize="24" FontWeight="Bold" Foreground="White"/>
                <Button x:Name="CheckoutButton" Content="Оформить заказ" Width="160" Height="45" FontSize="18" Margin="20,0" Click="CheckoutButton_Click"/>
                <Button x:Name="CatalogResButton" Content="Каталог" Width="100" Height="45"  FontSize="18" Margin="10,0" Click="CatalogResButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
