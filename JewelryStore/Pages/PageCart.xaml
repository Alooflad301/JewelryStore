<Page x:Class="JewelryStore.Pages.PageCart"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JewelryStore.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageCart">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Margin="5,0,20,0" Content="удалить" Height="26"/>
            <Button Grid.Column="1" Margin="5,0,20,0" Content="" Height="26" />
            <Button Grid.Column="2" Margin="5,0,20,0" Content="Сброс" Height="26" />
        </Grid>
        <ListView Grid.Row="1" x:Name="listProduct" Margin="5,0,20,0">
            <ListView.Background>
                <RadialGradientBrush>
                    <GradientStop Color="#FFCACACA" Offset="0"/>
                    <GradientStop Color="#FFA0A0A0" Offset="1"/>
                </RadialGradientBrush>
            </ListView.Background>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="400"/>
                            </Grid.ColumnDefinitions>
                            <Border
                         Width="200"
                         Height="200"
                         Margin="3"
                         ClipToBounds="True"
                         Grid.Column="0">
                                <Image Source="{Binding CurrentPhoto}" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel  Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Left">
                                <TextBlock  Height="auto" Text="{Binding NameJewelry}"/>
                                <TextBlock TextWrapping="Wrap" Height="auto" Margin="0,0,0,20">
                         <Run Text="Категория укарашения: "/>
                          <Run Text="{Binding JewelryTip.NameJewelryTip}"/>

                                </TextBlock>
                                <TextBlock TextWrapping="Wrap"  Height="auto" Margin="0,0,0,20">
                                 <Run Text="Материал: "/>
                                 <Run Text="{Binding Material.NameMaterial}"/>

                                </TextBlock>
                                <TextBlock TextWrapping="Wrap"  Height="auto" Margin="0,0,0,10">
                                 <Run Text="Камень: "/>
                                 <Run Text="{Binding Stone.NameStone}"/>

                                </TextBlock>
                                <TextBlock TextWrapping="Wrap"  Height="auto" Margin="0,0,0,10">
 <Run Text="Бренд: "/>
 <Run Text="{Binding Supplier.NameSupplier}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock TextWrapping="Wrap"  Height="auto" Margin="0,0,0,10">
                                         <Run Text="Цена: "/>
                                         <Run Text="{Binding PriceJewelry}"/>
                                         <Run Text=" руб."/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="tbCounter" Grid.Column="0" HorizontalAlignment="Left" Margin="10,0,0,0" TextWrapping="Wrap" Text="TextBlock" VerticalAlignment="Center" Foreground="White" FontSize="18"/>
        </Grid>

        <Grid.Background>
            <RadialGradientBrush>
                <GradientStop Color="#FFD41891" Offset="0"/>
                <GradientStop Color="#FF421A56" Offset="1"/>
                <GradientStop Color="#FFAF0000" Offset="2"/>
                <GradientStop Color="#FFC11C02" Offset="2"/>
                <GradientStop Color="#FFFF0404" Offset="4"/>
            </RadialGradientBrush>
        </Grid.Background>
    </Grid>
</Page>
