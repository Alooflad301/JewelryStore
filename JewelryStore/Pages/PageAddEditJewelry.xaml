<Page x:Class="JewelryStore.Pages.PageAddEditJewelry"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="PageAddEditJewelry" Loaded="Page_Loaded">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF64FB82"/>
                <GradientStop Color="#FF54A564" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Добавить/Редактировать товар" 
                   FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" 
                   Margin="20" Foreground="Black" FontFamily="Nirmala UI"/>

        <!-- Форма -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- Название -->
                <TextBlock Text="Название украшения:" FontWeight="Bold" Margin="0,10,0,5" FontSize="16" FontFamily="Nirmala UI"/>
                <TextBox x:Name="NameJewelryText" Height="30" FontSize="16" FontFamily="Nirmala UI"/>

                <!-- Тип -->
                <TextBlock Text="Тип украшения:" FontWeight="Bold" Margin="0,10,0,5" FontSize="16" FontFamily="Nirmala UI"/>
                <ComboBox x:Name="JewelryTipCombo" Height="30" FontSize="16" 
                          DisplayMemberPath="NameJewelryTip" SelectedValuePath="IdJewelryTip" FontFamily="Nirmala UI"/>

                <!-- Материал -->
                <TextBlock Text="Материал:" FontWeight="Bold" Margin="0,10,0,5" FontFamily="Nirmala UI" FontSize="16"/>
                <ComboBox x:Name="MaterialCombo"
          Height="30"
          FontSize="16"
          FontFamily="Nirmala UI"
          SelectedValuePath="IdMaterial">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding NameMaterial}" FontSize="16"/>
                                <TextBlock Text=" (" FontSize="14"/>
                                <TextBlock Text="{Binding Proba}" FontSize="14"/>
                                <TextBlock Text=")" FontSize="14"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Камень -->
                <TextBlock Text="Камень:" FontWeight="Bold" Margin="0,10,0,5" FontFamily="Nirmala UI" FontSize="16"/>
                <ComboBox x:Name="StoneCombo" Height="30" FontSize="16" 
                          DisplayMemberPath="NameStone" SelectedValuePath="IdStone" FontFamily="Nirmala UI"/>

                <!-- Поставщик -->
                <TextBlock Text="Поставщик:" FontWeight="Bold" Margin="0,10,0,5" FontFamily="Nirmala UI" FontSize="16"/>
                <ComboBox x:Name="SupplierCombo" Height="30" FontSize="16" 
                          DisplayMemberPath="NameSupplier" SelectedValuePath="IdSupplier" FontFamily="Nirmala UI"/>

                <!-- Цена -->
                <TextBlock Text="Цена (руб.):" FontWeight="Bold" Margin="0,10,0,5" FontFamily="Nirmala UI" FontSize="16"/>
                <TextBox x:Name="PriceText" Height="30" FontSize="16"/>

                <!-- Изображение -->
                <TextBlock Text="Изображение:" FontWeight="Bold" Margin="0,10,0,5" FontSize="16" FontFamily="Nirmala UI"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ImagePathText" Grid.Column="0" Height="30" FontSize="16"/>
                    <Button x:Name="SelectImageBtn" Grid.Column="1" Content="📁 Выбрать" 
                            Width="100" Height="30" Margin="5,0,0,0" Click="SelectImageBtn_Click" FontFamily="Nirmala UI" FontSize="16" FontWeight="Bold"/>
                </Grid>
                <Image x:Name="ImagePreview" Height="150" Stretch="Uniform" Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="SaveButton" Content="Сохранить" Width="120" Height="40" 
                    FontSize="18" Margin="10" Click="SaveButton_Click" Background="White" FontFamily="Nirmala UI" FontWeight="Bold"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="120" Height="40" 
                    FontSize="18" Margin="10" Click="CancelButton_Click" Background="White" FontFamily="Nirmala UI" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Page>