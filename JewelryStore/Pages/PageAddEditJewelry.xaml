<Page x:Class="JewelryStore.Pages.PageAddEditJewelry"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="PageAddEditJewelry" Loaded="Page_Loaded">

    <Grid Background="#FFF0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Добавить/Редактировать товар" 
                   FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" 
                   Margin="20" Foreground="#FF421A56"/>

        <!-- Форма -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <!-- Название -->
                <TextBlock Text="Название украшения:" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="NameJewelryText" Height="30" FontSize="16"/>

                <!-- Тип -->
                <TextBlock Text="Тип украшения:" FontWeight="Bold" Margin="0,10,0,5"/>
                <ComboBox x:Name="JewelryTipCombo" Height="30" FontSize="16" 
                          DisplayMemberPath="NameJewelryTip" SelectedValuePath="IdJewelryTip"/>

                <!-- Материал -->
                <TextBlock Text="Материал:" FontWeight="Bold" Margin="0,10,0,5"/>
                <ComboBox x:Name="MaterialCombo" Height="30" FontSize="16" 
                          DisplayMemberPath="NameMaterial" SelectedValuePath="IdMaterial"/>

                <!-- Камень -->
                <TextBlock Text="Камень:" FontWeight="Bold" Margin="0,10,0,5"/>
                <ComboBox x:Name="StoneCombo" Height="30" FontSize="16" 
                          DisplayMemberPath="NameStone" SelectedValuePath="IdStone"/>

                <!-- Поставщик -->
                <TextBlock Text="Поставщик:" FontWeight="Bold" Margin="0,10,0,5"/>
                <ComboBox x:Name="SupplierCombo" Height="30" FontSize="16" 
                          DisplayMemberPath="NameSupplier" SelectedValuePath="IdSupplier"/>

                <!-- Цена -->
                <TextBlock Text="Цена (руб.):" FontWeight="Bold" Margin="0,10,0,5"/>
                <TextBox x:Name="PriceText" Height="30" FontSize="16"/>

                <!-- Изображение -->
                <TextBlock Text="Изображение:" FontWeight="Bold" Margin="0,10,0,5"/>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ImagePathText" Grid.Column="0" Height="30" FontSize="16"/>
                    <Button x:Name="SelectImageBtn" Grid.Column="1" Content="📁 Выбрать" 
                            Width="100" Height="30" Margin="5,0,0,0" Click="SelectImageBtn_Click"/>
                </Grid>
                <Image x:Name="ImagePreview" Height="150" Stretch="Uniform" Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="SaveButton" Content="💾 Сохранить" Width="120" Height="40" 
                    FontSize="18" Margin="10" Click="SaveButton_Click"/>
            <Button x:Name="CancelButton" Content="❌ Отмена" Width="120" Height="40" 
                    FontSize="18" Margin="10" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Page>